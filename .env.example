# ===== Servidor =====
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# ===== Banco =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_reports?schema=public

# ===== Google OAuth (robo machine-to-machine: Drive + Chat + People) =====
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ===== Google Sign-In (login humano) =====
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/login/callback
# Dominio Workspace permitido (Google `hd` claim). Apenas e-mails desse dominio
# conseguem entrar no dashboard.
ALLOWED_HD=grupodpg.com.br

# ===== Sessao =====
# >= 32 caracteres. Gerar com:  openssl rand -hex 32
SESSION_SECRET=change_me_to_a_32_plus_char_random_string_xxxxxxxx

# ===== Storage de tokens do robo (long-lived) =====
TOKEN_STORE_PATH=data/tokens.json

# ===== Geracao de relatorio =====
REPORT_FORMAT_DEFAULT=pdf

# ===== Gemini =====
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
