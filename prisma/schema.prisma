generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id               String   @id @default(cuid())
  driveFileId      String
  driveLink        String
  summary          Json
  generatedAt      DateTime @default(now())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  generatedByEmail String?

  @@index([generatedByEmail])
}

model SearchLog {
  id              String   @id @default(cuid())
  term            String
  createdAt       DateTime @default(now())
  searchedByEmail String?

  @@index([searchedByEmail])
}
