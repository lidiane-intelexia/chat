{
  "name": "chat-report-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@google/genai": "1.46.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "7.4.1",
    "fastest-levenshtein": "1.0.16",
    "googleapis": "171.4.0",
    "helmet": "8.0.0",
    "p-limit": "7.3.0",
    "pdfkit": "0.17.2",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "puppeteer": "24.39.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "20.19.39",
    "@types/pdfkit": "0.17.5",
    "pino-pretty": "13.1.3",
    "prisma": "7.4.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
